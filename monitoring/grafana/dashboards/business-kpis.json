{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Select the Prometheus datasource",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    },
    {
      "name": "DS_LOKI",
      "label": "Loki",
      "description": "Select the Loki datasource",
      "type": "datasource",
      "pluginId": "loki",
      "pluginName": "Loki"
    }
  ],
  "__requires": [
    { "type": "grafana",    "id": "grafana",    "name": "Grafana",    "version": "9.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "datasource", "id": "loki",       "name": "Loki",       "version": "1.0.0" },
    { "type": "panel",      "id": "stat",       "name": "Stat",       "version": "" },
    { "type": "panel",      "id": "timeseries", "name": "Time series","version": "" },
    { "type": "panel",      "id": "gauge",      "name": "Gauge",      "version": "" }
  ],
  "title": "Ninetech – Business KPIs",
  "uid": "ninetech-business",
  "description": "Domain-level metrics: active athletes, sponsorships, registration rates. Requires backend to expose custom Prometheus counters.",
  "tags": ["ninetech", "business", "kpi"],
  "schemaVersion": 38,
  "version": 1,
  "editable": true,
  "graphTooltip": 0,
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "refresh": "1m",
  "links": [],
  "annotations": { "list": [] },
  "templating": { "list": [] },
  "panels": [

    {
      "id": 1,
      "title": "Active Athletes",
      "type": "stat",
      "description": "Current number of active athletes in the platform. Updated by backend gauge.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "active_athletes_total",
          "legendFormat": "athletes"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "blue", "value": null } ] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "sparkline": { "show": true } },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 }
    },

    {
      "id": 2,
      "title": "Active Sponsorships",
      "type": "stat",
      "description": "Current number of active athlete–sponsor relationships.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "active_sponsorships_total",
          "legendFormat": "sponsorships"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "sparkline": { "show": true } },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 }
    },

    {
      "id": 3,
      "title": "New Sponsorships (last 24 h)",
      "type": "stat",
      "description": "Sponsorships created in the last 24 hours.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "increase(sponsorships_created_total[24h])",
          "legendFormat": "new"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "blue", "value": null } ] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 }
    },

    {
      "id": 4,
      "title": "New Athlete Registrations (last 24 h)",
      "type": "stat",
      "description": "Athletes who registered in the last 24 hours.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "increase(athlete_registrations_total[24h])",
          "legendFormat": "registrations"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "purple", "value": null } ] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 }
    },

    {
      "id": 5,
      "title": "Sponsorships Created Over Time",
      "type": "timeseries",
      "description": "Cumulative sponsorship creation rate. A flattening line means growth has stalled.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(sponsorships_created_total[1h])",
          "legendFormat": "sponsorships/hr"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        }
      },
      "options": { "tooltip": { "mode": "single" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 }
    },

    {
      "id": 6,
      "title": "Athlete Registrations Over Time",
      "type": "timeseries",
      "description": "New athlete registrations per hour.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(athlete_registrations_total[1h])",
          "legendFormat": "registrations/hr"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        }
      },
      "options": { "tooltip": { "mode": "single" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 }
    },

    {
      "id": 7,
      "title": "API Error Breakdown (from Logs)",
      "type": "logs",
      "description": "Business-level errors (e.g. validation, auth) from structured logs.",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "refId": "A",
          "expr": "{app=\"backend\"} | json | level=~\"(?i)(error|warn)\"",
          "legendFormat": ""
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 13 }
    }

  ]
}