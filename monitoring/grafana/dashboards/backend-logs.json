{
  "__inputs": [
    {
      "name": "DS_LOKI",
      "label": "Loki",
      "description": "Select the Loki datasource",
      "type": "datasource",
      "pluginId": "loki",
      "pluginName": "Loki"
    }
  ],
  "__requires": [
    { "type": "grafana",    "id": "grafana",    "name": "Grafana",    "version": "9.0.0" },
    { "type": "datasource", "id": "loki",       "name": "Loki",       "version": "1.0.0" },
    { "type": "panel",      "id": "logs",       "name": "Logs",       "version": "" },
    { "type": "panel",      "id": "stat",       "name": "Stat",       "version": "" },
    { "type": "panel",      "id": "timeseries", "name": "Time series","version": "" }
  ],
  "panels": [

    {
      "id": 1,
      "title": "Error count (last window)",
      "type": "stat",
      "description": "Number of ERROR-level log lines in the selected time window.",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({app=\"$app\"} | json | level=~\"(?i)error\" [5m]))",
          "legendFormat": "errors"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red",    "value": 10 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "background" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 }
    },

    {
      "id": 2,
      "title": "Log volume (lines/min)",
      "type": "timeseries",
      "description": "Log throughput broken down by level. Spikes may indicate issues.",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (level) (rate({app=\"$app\"} | json [1m]))",
          "legendFormat": "{{level}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "logs",
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "ERROR" }, "properties": [ { "id": "color", "value": { "fixedColor": "red",    "mode": "fixed" } } ] },
          { "matcher": { "id": "byName", "options": "WARN"  }, "properties": [ { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } } ] },
          { "matcher": { "id": "byName", "options": "INFO"  }, "properties": [ { "id": "color", "value": { "fixedColor": "blue",   "mode": "fixed" } } ] }
        ]
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" } },
      "gridPos": { "h": 4, "w": 18, "x": 6, "y": 0 }
    },

    {
      "id": 3,
      "title": "All Logs",
      "type": "logs",
      "description": "Live log stream. Filter by level dropdown or traceId above.",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "refId": "A",
          "expr": "{app=\"$app\"}${level != \"All\" ? \" | json | level=~\\\"(?i)\" + level + \"\\\"\" : \"\"}${traceId != \"\" ? \" | json | traceId=\\\"\" + traceId + \"\\\"\" : \"\"}",
          "legendFormat": ""
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 4 }
    },

    {
      "id": 4,
      "title": "Error Logs",
      "type": "logs",
      "description": "Only ERROR and FATAL lines — fast triage panel.",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "refId": "A",
          "expr": "{app=\"$app\"} | json | level=~\"(?i)(error|fatal)\"",
          "legendFormat": ""
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 16 }
    },

    {
      "id": 5,
      "title": "Slow Requests (> 500 ms)",
      "type": "logs",
      "description": "Requests that exceed the p99 SLO. Check endpoint and userId for patterns.",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "refId": "A",
          "expr": "{app=\"$app\"} | json | durationMs > 500",
          "legendFormat": ""
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 26 }
    },

    {
      "id": 6,
      "title": "Trace — single request",
      "type": "logs",
      "description": "Enter a traceId in the template variable above to see every log line for that request.",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "refId": "A",
          "expr": "{app=\"$app\"} | json | traceId=\"$traceId\"",
          "legendFormat": ""
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Ascending",
        "wrapLogMessage": true
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 36 }
    }

  ]
}