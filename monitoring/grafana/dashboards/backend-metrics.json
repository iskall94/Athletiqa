{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Select the Prometheus datasource",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "piechart", "name": "Pie chart", "version": "" }
  ],
  "title": "Ninetech – Backend Metrics (RED)",
  "uid": "ninetech-backend-red",
  "description": "Request Rate, Error Rate, and Duration (RED method) for the Ninetech backend. Aligns with SLO: 99.5% availability, p99 < 500 ms, error rate < 1%.",
  "tags": ["ninetech", "backend", "slo", "red"],
  "schemaVersion": 38,
  "version": 1,
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "refresh": "30s",
  "links": [],
  "annotations": { "list": [] },
  "templating": {
    "list": [
      {
        "name": "namespace",
        "label": "Namespace",
        "type": "constant",
        "query": "doe25-fatimah-imad-salman-kbah",
        "current": { "value": "doe25-fatimah-imad-salman-kbah" },
        "hide": 2
      },
      {
        "name": "interval",
        "label": "Rate interval",
        "type": "interval",
        "query": "1m,5m,10m,30m,1h",
        "current": { "value": "5m", "text": "5m" },
        "auto": false,
        "hide": 0
      }
    ]
  },
  "panels": [

    {
      "id": 1,
      "title": "🟢 Availability (error rate < 1% = OK)",
      "type": "stat",
      "description": "SLO target: error rate < 1%. Green = within SLO.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "1 - (rate(http_requests_total{namespace=\"$namespace\",status=~\"5..\"}[$interval]) / rate(http_requests_total{namespace=\"$namespace\"}[$interval]))",
          "legendFormat": "Availability"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "orange", "value": 0.99 },
              { "color": "green",  "value": 0.995 }
            ]
          },
          "mappings": []
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 }
    },

    {
      "id": 2,
      "title": "⚡ p99 Latency (SLO < 500 ms)",
      "type": "stat",
      "description": "SLO target: p99 response time < 500 ms.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{namespace=\"$namespace\"}[$interval])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "orange", "value": 0.25 },
              { "color": "red",    "value": 0.5 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 }
    },

    {
      "id": 3,
      "title": "📈 Request Rate",
      "type": "stat",
      "description": "Total requests per second across all endpoints.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_requests_total{namespace=\"$namespace\"}[$interval]))",
          "legendFormat": "req/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 }
    },

    {
      "id": 4,
      "title": "🔴 Error Rate",
      "type": "stat",
      "description": "Fraction of requests returning 5xx. Alert fires at > 1%.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_requests_total{namespace=\"$namespace\",status=~\"5..\"}[$interval])) / sum(rate(http_requests_total{namespace=\"$namespace\"}[$interval]))",
          "legendFormat": "Error rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "orange", "value": 0.005 },
              { "color": "red",    "value": 0.01 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 }
    },

    {
      "id": 5,
      "title": "Request Rate by Endpoint",
      "type": "timeseries",
      "description": "Requests per second broken down by HTTP method and endpoint.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (method, endpoint) (rate(http_requests_total{namespace=\"$namespace\"}[$interval]))",
          "legendFormat": "{{method}} {{endpoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 }
    },

    {
      "id": 6,
      "title": "Error Rate by Endpoint",
      "type": "timeseries",
      "description": "Fraction of requests returning 5xx per endpoint.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (endpoint) (rate(http_requests_total{namespace=\"$namespace\",status=~\"5..\"}[$interval])) / sum by (endpoint) (rate(http_requests_total{namespace=\"$namespace\"}[$interval]))",
          "legendFormat": "{{endpoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red",   "value": 0.01 }
            ]
          }
        }
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 }
    },

    {
      "id": 7,
      "title": "Latency Percentiles (p50 / p95 / p99)",
      "type": "timeseries",
      "description": "Response time distribution. SLO: p99 < 500 ms.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{namespace=\"$namespace\"}[$interval])) by (le))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{namespace=\"$namespace\"}[$interval])) by (le))",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{namespace=\"$namespace\"}[$interval])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "p99" }, "properties": [ { "id": "custom.lineWidth", "value": 3 } ] }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 }
    },

    {
      "id": 8,
      "title": "HTTP Status Code Distribution",
      "type": "piechart",
      "description": "Breakdown of responses by status code family (2xx, 4xx, 5xx).",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status) (increase(http_requests_total{namespace=\"$namespace\"}[$interval]))",
          "legendFormat": "{{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": "^2.*" }, "properties": [ { "id": "color", "value": { "fixedColor": "green",  "mode": "fixed" } } ] },
          { "matcher": { "id": "byRegexp", "options": "^4.*" }, "properties": [ { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } } ] },
          { "matcher": { "id": "byRegexp", "options": "^5.*" }, "properties": [ { "id": "color", "value": { "fixedColor": "red",    "mode": "fixed" } } ] }
        ]
      },
      "options": { "pieType": "donut", "tooltip": { "mode": "single" }, "legend": { "displayMode": "list", "placement": "right" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 }
    },

    {
      "id": 9,
      "title": "Latency Heatmap (all endpoints)",
      "type": "timeseries",
      "description": "Average latency per endpoint over time — useful for spotting regressions after deploys.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (endpoint) (rate(http_request_duration_seconds_sum{namespace=\"$namespace\"}[$interval])) / sum by (endpoint) (rate(http_request_duration_seconds_count{namespace=\"$namespace\"}[$interval]))",
          "legendFormat": "avg {{endpoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 1, "fillOpacity": 5 }
        }
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" } },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 }
    }

  ]
}