{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "apiVersion": 1,
  "groups": [
    {
      "orgId": 1,
      "name": "Ninetech SLO Alerts",
      "folder": "Ninetech",
      "interval": "1m",
      "rules": [

        {
          "uid": "ninetech-high-error-rate",
          "title": "High Error Rate",
          "condition": "B",
          "data": [
            {
              "refId": "A",
              "datasourceUid": "${DS_PROMETHEUS}",
              "model": {
                "expr": "sum(rate(http_requests_total{namespace=\"doe25-fatimah-imad-salman-kbah\",status=~\"5..\"}[5m])) / sum(rate(http_requests_total{namespace=\"doe25-fatimah-imad-salman-kbah\"}[5m]))",
                "instant": true,
                "refId": "A"
              }
            },
            {
                
              "refId": "B",
              "datasourceUid": "-100",
              "model": {
                "conditions": [
                  {
                    "evaluator": { "params": [0.01], "type": "gt" },
                    "operator":  { "type": "and" },
                    "query":     { "params": ["A"] },
                    "reducer":   { "params": [], "type": "last" },
                    "type": "query"
                  }
                ],
                "datasource": { "type": "__expr__", "uid": "-100" },
                "refId": "B",
                "type": "classic_conditions"
              }
            }
          ],
          "dashboardUid": "ninetech-backend-red",
          "panelId": 4,
          "noDataState": "NoData",
          "execErrState": "Error",
          "for": "5m",
          "annotations": {
            "summary": "Backend error rate exceeds SLO (1%)",
            "description": "Error rate is {{ $value | humanizePercentage }} over the last 5 minutes. SLO target: < 1%. Check the Backend Logs dashboard for details."
          },
          "labels": {
            "severity": "critical",
            "team": "ninetech",
            "slo": "availability"
          },
          "isPaused": false
        },

        {
          "uid": "ninetech-high-latency-p99",
          "title": "High Latency (p99)",
          "condition": "B",
          "data": [
            {
              "refId": "A",
              "datasourceUid": "${DS_PROMETHEUS}",
              "model": {
                "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{namespace=\"doe25-fatimah-imad-salman-kbah\"}[5m])) by (le))",
                "instant": true,
                "refId": "A"
              }
            },
            {
              "refId": "B",
              "datasourceUid": "-100",
              "model": {
                "conditions": [
                  {
                    "evaluator": { "params": [0.5], "type": "gt" },
                    "operator":  { "type": "and" },
                    "query":     { "params": ["A"] },
                    "reducer":   { "params": [], "type": "last" },
                    "type": "query"
                  }
                ],
                "datasource": { "type": "__expr__", "uid": "-100" },
                "refId": "B",
                "type": "classic_conditions"
              }
            }
          ],
          "dashboardUid": "ninetech-backend-red",
          "panelId": 7,
          "noDataState": "NoData",
          "execErrState": "Error",
          "for": "10m",
          "annotations": {
            "summary": "Backend p99 latency exceeds SLO (500 ms)",
            "description": "p99 response time is {{ $value | humanizeDuration }} (threshold: 500 ms). Check slow endpoints in the Backend Metrics dashboard."
          },
          "labels": {
            "severity": "warning",
            "team": "ninetech",
            "slo": "latency"
          },
          "isPaused": false
        },

        {
          "uid": "ninetech-service-down",
          "title": "Backend Service Down",
          "condition": "B",
          "data": [
            {
              "refId": "A",
              "datasourceUid": "${DS_PROMETHEUS}",
              "model": {
                "expr": "sum(rate(http_requests_total{namespace=\"doe25-fatimah-imad-salman-kbah\"}[2m]))",
                "instant": true,
                "refId": "A"
              }
            },
            {
              "refId": "B",
              "datasourceUid": "-100",
              "model": {
                "conditions": [
                  {
                    "evaluator": { "params": [0], "type": "lt" },
                    "operator":  { "type": "and" },
                    "query":     { "params": ["A"] },
                    "reducer":   { "params": [], "type": "last" },
                    "type": "query"
                  }
                ],
                "datasource": { "type": "__expr__", "uid": "-100" },
                "refId": "B",
                "type": "classic_conditions"
              }
            }
          ],
          "noDataState": "Alerting",
          "execErrState": "Error",
          "for": "2m",
          "annotations": {
            "summary": "Backend service is not receiving traffic",
            "description": "No HTTP requests have been recorded for 2 minutes. The backend pod may be crash-looping or the ingress may be misconfigured. Run: kubectl get pods -n doe25-fatimah-imad-salman-kbah"
          },
          "labels": {
            "severity": "critical",
            "team": "ninetech",
            "slo": "availability"
          },
          "isPaused": false
        },

        {
          "uid": "ninetech-mssql-exporter-down",
          "title": "MSSQL Exporter Down",
          "condition": "B",
          "data": [
            {
              "refId": "A",
              "datasourceUid": "${DS_PROMETHEUS}",
              "model": {
                "expr": "up{namespace=\"doe25-fatimah-imad-salman-kbah\", app=\"mssql-exporter\"}",
                "instant": true,
                "refId": "A"
              }
            },
            {
              "refId": "B",
              "datasourceUid": "-100",
              "model": {
                "conditions": [
                  {
                    "evaluator": { "params": [1], "type": "lt" },
                    "operator":  { "type": "and" },
                    "query":     { "params": ["A"] },
                    "reducer":   { "params": [], "type": "last" },
                    "type": "query"
                  }
                ],
                "datasource": { "type": "__expr__", "uid": "-100" },
                "refId": "B",
                "type": "classic_conditions"
              }
            }
          ],
          "noDataState": "Alerting",
          "execErrState": "Error",
          "for": "3m",
          "annotations": {
            "summary": "MSSQL Exporter is not reachable",
            "description": "Prometheus cannot scrape the MSSQL exporter. Database metrics are unavailable. This may indicate the database or exporter pod has crashed."
          },
          "labels": {
            "severity": "warning",
            "team": "ninetech"
          },
          "isPaused": false
        },

        {
          "uid": "ninetech-promtail-no-logs",
          "title": "Promtail – No Logs Shipped",
          "condition": "B",
          "data": [
            {
              "refId": "A",
              "datasourceUid": "${DS_PROMETHEUS}",
              "model": {
                "expr": "rate(promtail_sent_entries_total{namespace=\"doe25-fatimah-imad-salman-kbah\"}[5m])",
                "instant": true,
                "refId": "A"
              }
            },
            {
              "refId": "B",
              "datasourceUid": "-100",
              "model": {
                "conditions": [
                  {
                    "evaluator": { "params": [0], "type": "lt" },
                    "operator":  { "type": "and" },
                    "query":     { "params": ["A"] },
                    "reducer":   { "params": [], "type": "last" },
                    "type": "query"
                  }
                ],
                "datasource": { "type": "__expr__", "uid": "-100" },
                "refId": "B",
                "type": "classic_conditions"
              }
            }
          ],
          "noDataState": "NoData",
          "execErrState": "Error",
          "for": "10m",
          "annotations": {
            "summary": "Promtail has stopped shipping logs",
            "description": "No log entries have been sent to Loki for 10 minutes. Check: kubectl logs daemonset/promtail -n doe25-fatimah-imad-salman-kbah"
          },
          "labels": {
            "severity": "warning",
            "team": "ninetech"
          },
          "isPaused": false
        }

      ]
    }
  ]
}
